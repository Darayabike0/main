📄 wrangler.toml

`toml
name = "invoice-appdarayar-worker"
main = "src/index.js"
compatibility_date = "2026-01-31"

[vars]
คนงาน.พัฒนา = "app-darayar.invoice-appdarayarworkersdev.workers.dev"
ดูตัวอย่างURL = "*app-darayar.invoice-appdarayarworkersdev.workers.dev"

[env.development]
vars = { 
  คนงาน.พัฒนา = "app-darayar.invoice-appdarayarworkersdev.workers.dev",
  ดูตัวอย่างURL = "*-app-darayar.invoice-appdarayarworkersdev.workers.dev"
}

[env.production]
vars = { 
  คนงาน.พัฒนา = "app-darayar.invoice-appdarayarworkersdev.workers.dev",
  ดูตัวอย่างURL = "*-app-darayar.invoice-appdarayarworkersdev.workers.dev"
