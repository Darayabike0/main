📄 src/index.js

`javascript
export default {
  async fetch(request, env) {
    const domain = env["คนงาน.พัฒนา"];
    const previewPattern = env["ดูตัวอย่างURL"];
    const url = new URL(request.url);

    if (url.host === domain || url.host.match(previewPattern)) {
      return new Response(
        ✅ Worker เข้าถึงได้\nHost: ${url.host}\nDomain: ${domain}\nPattern: ${previewPattern},
        { status: 200 }
      );
    }

    return new Response("❌ ไม่อนุญาตให้เข้าถึง", { status: 403 });
  }
};
`

